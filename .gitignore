# Ignore local datasets (DVC tracks raw datasets, processed splits shouldn't be checked in)
/data/raw/
/data/processed/

# Ignore serialized models and preprocessors in the root models folder
/models/

# Ignore temporary plots generated during training
/temp_plots/
temp_plots/

